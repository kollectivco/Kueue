#, php-format
msgid " is required for %1$s attendee %2$d"
msgstr " est requis pour %1$s participant %2$d"

#: class-fooevents-custom-attendee-fields.php:755
#, php-format
msgid " is not a valid email address for %s attendee %d"
msgstr " n'est pas une adresse e-mail valide pour le participant %s numéro %d"

