#: class-fooevents-custom-attendee-fields.php:160
msgid "The FooEvents Custom Attendee Fields plugin requires FooEvents for WooCommerce to be installed."
msgstr "Il plugin FooEvents Custom Attendee Fields richiede l'installazione di FooEvents for WooCommerce."

#: class-fooevents-custom-attendee-fields.php:194
msgid "Attendee"
msgstr "Partecipante"

#: class-fooevents-custom-attendee-fields.php:548
#: class-fooevents-custom-attendee-fields.php:595
#, php-format
msgid "%s is a required field."
msgstr "%s è un campo obbligatorio."

#: class-fooevents-custom-attendee-fields.php:745
#, php-format
msgid " is required for %1$s attendee %2$d"
msgstr " è richiesto per %1$s partecipante %2$d"

#: class-fooevents-custom-attendee-fields.php:755
#, php-format
msgid " is not a valid email address for %s attendee %d"
msgstr " non è un indirizzo email valido per l'ospite %s numero %d"

#: class-fooevents-custom-attendee-fields.php:763
#, php-format
msgid " is not a valid URL for %s attendee %d"
msgstr " non è un URL valido per l'ospite %s numero %d"

#: class-fooevents-custom-attendee-fields.php:771
#, php-format
msgid " is not a valid number for %s attendee %d"
msgstr " non è un numero valido per %s partecipante %d"

#: class-fooevents-custom-attendee-fields.php:779
#, php-format
msgid " needs to contain only alphabet characters for %s attendee %d"
msgstr " deve contenere solo caratteri alfabetici per %s partecipante %d"

#: class-fooevents-custom-attendee-fields.php:787
#, php-format
msgid " needs to contain only alphabet or number characters for %s attendee %d"
msgstr " deve contenere solo caratteri alfabetici o numerici per %s partecipante %d"

#: classes/updatehelper.php:214
msgid "Important:"
msgstr "Importante:"

#: classes/updatehelper.php:227
msgid "Please backup your files and database before updates!"
msgstr "Si prega di fare il backup dei file e del database prima degli aggiornamenti!"

#: templates/custom-attendee-fields-options.php:15
msgid "FooEvents does not currently support capturing custom attendee field details using the new WooCommerce Checkout block. To enable this functionality, please switch to the classic shortcode-based WooCommerce Checkout experience."
msgstr "FooEvents attualmente non supporta la cattura dei dettagli dei campi personalizzati dei partecipanti utilizzando il nuovo blocco di Checkout di WooCommerce. Per abilitare questa funzionalità, si prega di passare all'esperienza di Checkout classica basata su shortcode di WooCommerce."

