msgstr "Kortings titel"

#: admin/helpers/fooeventspos-phrases-helper.php:373
msgid "Title of the discounts field (e.g. \"Discounts\")."
msgstr "Titel van die afslagveld (bv. \"Afslag\")."

#: admin/helpers/fooeventspos-phrases-helper.php:374
msgid "Exclusive abbreviation"
msgstr "Uitgeslote afkorting"

#: admin/helpers/fooeventspos-phrases-helper.php:375
msgid "Abbreviation to indicate the exclusive price (e.g. \"excl.\")."
msgstr "Afkorting om die eksklusiewe prys aan te dui (bv. \"exkl.\")."

#: admin/helpers/fooeventspos-phrases-helper.php:376
msgid "Fetch order notes"
msgstr "Haal bestellingsnotas op"

#: admin/helpers/fooeventspos-phrases-helper.php:377
msgid "The FooEvents POS app will fetch and display corresponding order notes in the Order Details section. This may cause performance issues and the FooEvents POS app might run out of memory on certain platforms when a large volume of orders is fetched. Disabling this setting will still load notes to customers."
msgstr "Die FooEvents POS-toep sal ooreenstemmende bestellingsnotas ophaal en vertoon in die Bestellingsbesonderhede-afdeling. Dit kan tot prestasieprobleme lei en die FooEvents POS-toep kan op sekere platforms geheue verloor wanneer 'n groot volume bestellings opgehaal word. Die deaktivering van hierdie instelling sal steeds notas aan kliënte laai."

#: admin/helpers/fooeventspos-phrases-helper.php:378
msgid "Display FooEvents POS logo"
msgstr "Vertoon FooEvents POS-logo"

#: admin/helpers/fooeventspos-phrases-helper.php:379
msgid "Footer content"
msgstr "Voetstukinhoud"

