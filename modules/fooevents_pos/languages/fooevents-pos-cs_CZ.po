msgstr "Zachytit ruční zadání karty pomocí Square (pouze webová aplikace FooEvents POS). %1$sNastavit Square%2$s"

#: admin/helpers/fooeventspos-phrases-helper.php:134
#, php-format
msgid "Accept payments using a Square Reader. %1$sConfigure Square%2$s"
msgstr "Přijímejte platby pomocí Square Readeru. %1$sNastavte Square%2$s"

#: admin/helpers/fooeventspos-phrases-helper.php:136
#, php-format
msgid "Accept payments using a Square Terminal. %1$sConfigure Square%2$s"
msgstr "Přijímejte platby pomocí Square Terminalu. %1$sNastavte Square%2$s"

#: admin/helpers/fooeventspos-phrases-helper.php:138
#, php-format
msgid "Accept payments using Stripe BBPOS Chipper™ Bluetooth readers. %1$sConfigure Stripe%2$s"
msgstr "Přijímejte platby pomocí čteček Stripe BBPOS Chipper™ Bluetooth. %1$sNastavit Stripe%2$s"

#: admin/helpers/fooeventspos-phrases-helper.php:140
#, php-format
msgid "Capture manual card entries using Stripe. %1$sConfigure Stripe%2$s"
msgstr "Zachytit ruční zadání karty pomocí Stripe. %1$sNastavit Stripe%2$s"

#: admin/helpers/fooeventspos-phrases-helper.php:142
#, php-format
msgid "Accept payments using Stripe S700, BBPOS WisePOS™ E or Verifone P400 readers. %1$sConfigure Stripe%2$s"
msgstr "Přijímejte platby pomocí čteček Stripe S700, BBPOS WisePOS™ E nebo Verifone P400. %1$sNastavit Stripe%2$s"

#: admin/helpers/fooeventspos-phrases-helper.php:144
#, php-format
