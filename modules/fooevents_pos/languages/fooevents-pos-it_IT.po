#: admin/helpers/fooeventspos-phrases-helper.php:16
msgid "Activate Free Trial"
msgstr "Attiva la prova gratuita"

#: admin/helpers/fooeventspos-phrases-helper.php:17
msgid "Install Android Tablet App"
msgstr "Installa l'applicazione per tablet Android."

#: admin/helpers/fooeventspos-phrases-helper.php:18
msgid "Clear"
msgstr "Chiaro"

#: admin/helpers/fooeventspos-phrases-helper.php:19
msgid "Click here"
msgstr "Clicca qui"

#: admin/helpers/fooeventspos-phrases-helper.php:20
msgid "Clipboard copied!"
msgstr "Testo copiato negli appunti!"

#: admin/helpers/fooeventspos-phrases-helper.php:21
msgid "Copy to clipboard"
msgstr "Copia negli appunti"

#: admin/helpers/fooeventspos-phrases-helper.php:22
msgid "Importing please wait..."
msgstr "Importazione in corso..."

#: admin/helpers/fooeventspos-phrases-helper.php:23
msgid "Install iPad App"
msgstr "Installa l'applicazione per iPad."

#: admin/helpers/fooeventspos-phrases-helper.php:24
msgid "Launch FooEvents POS"
msgstr "Lanciare FooEvents POS."

#: admin/helpers/fooeventspos-phrases-helper.php:25
msgid "My Account"
msgstr "Il mio account"

#: admin/helpers/fooeventspos-phrases-helper.php:26
msgid "Purchase a Plan"
msgstr "Acquista un Piano"

#: admin/helpers/fooeventspos-phrases-helper.php:27
msgid "Save"
msgstr "Salva"

#: admin/helpers/fooeventspos-phrases-helper.php:28
msgid "Saved!"
msgstr "Salvato!"

#: admin/helpers/fooeventspos-phrases-helper.php:29
msgid "Saving..."
msgstr "Salvataggio..."

#: admin/helpers/fooeventspos-phrases-helper.php:30
msgid "Search POS Payments"
msgstr "Cerca pagamenti POS"

#: admin/helpers/fooeventspos-phrases-helper.php:31
msgid "Contact Us"
msgstr "Contattaci"

#: admin/helpers/fooeventspos-phrases-helper.php:32
msgid "Try Again"
msgstr "Riprova."

#: admin/helpers/fooeventspos-phrases-helper.php:33
msgid "Update Orders"
msgstr "Aggiorna Ordini"

#: admin/helpers/fooeventspos-phrases-helper.php:34
msgid "Upload file and import"
msgstr "Carica file e importa"

#: admin/helpers/fooeventspos-phrases-helper.php:35
msgid "Select icon"
msgstr "Seleziona icona"

#: admin/helpers/fooeventspos-phrases-helper.php:36
msgid "Select logo"
msgstr "Seleziona logo"

#: admin/helpers/fooeventspos-phrases-helper.php:37
msgid "View transaction"
msgstr "Visualizza transazione"

#: admin/helpers/fooeventspos-phrases-helper.php:38
msgid "View payment"
msgstr "Visualizza pagamento"

#: admin/helpers/fooeventspos-phrases-helper.php:39
msgid "Disables sending new order emails in WooCommerce for orders created in the FooEvents POS app."
msgstr "Disabilita l'invio di nuovi messaggi di posta elettronica di ordine in WooCommerce per gli ordini creati nell'app FooEvents POS."

#: admin/helpers/fooeventspos-phrases-helper.php:40
msgid "Email tickets when purchased through FooEvents POS"
msgstr "Invia biglietti via email quando acquistati tramite FooEvents POS."

#: admin/helpers/fooeventspos-phrases-helper.php:41
msgid "Emails event tickets to the attendee or purchaser if the ticket was purchased through FooEvents POS."
msgstr "Invia per email i biglietti dell'evento al partecipante o all'acquirente se il biglietto è stato acquistato tramite FooEvents POS."

#: admin/helpers/fooeventspos-phrases-helper.php:42
msgid "Enable order analytics"
msgstr "Abilita l'analisi degli ordini."

#: admin/helpers/fooeventspos-phrases-helper.php:43
msgid "Allow FooEvents POS to anonymously collect non-sensitive data for orders placed through the FooEvents POS app such as order totals, country and payment method (to opt out, leave this box unchecked)."
msgstr "Consenti a FooEvents POS di raccogliere in modo anonimo dati non sensibili per gli ordini effettuati tramite l'app FooEvents POS, come totali degli ordini, paese e metodo di pagamento (per non partecipare, lascia questa casella deselezionata)."

#: admin/helpers/fooeventspos-phrases-helper.php:44
msgid "Enable 'Sales Channel' filter"
msgstr "Abilita il filtro 'Canale di vendita'"

#: admin/helpers/fooeventspos-phrases-helper.php:45
msgid "Enables a 'Sales Channel' filter on the Orders report in WooCommerce Analytics so you can filter between orders placed online and through the FooEvents POS app."
msgstr "Abilita un filtro 'Canale di vendita' nel rapporto degli ordini nelle analisi di WooCommerce in modo da poter filtrare tra gli ordini effettuati online e tramite l'app FooEvents POS."

#: admin/helpers/fooeventspos-phrases-helper.php:46
msgid "Use FooEvents Check-ins app appearance settings"
msgstr "Utilizzare le impostazioni dell'aspetto dell'app FooEvents Check-ins."

#: admin/helpers/fooeventspos-phrases-helper.php:47
msgid "Use the same custom appearance settings for FooEvents POS that are selected for the Check-ins app."
msgstr "Utilizza le stesse impostazioni di aspetto personalizzate per l'app FooEvents POS che sono selezionate per l'app Check-ins."

#: admin/helpers/fooeventspos-phrases-helper.php:48
msgid "Disabling this option could result in products loading faster and less memory used depending on the amount of products loaded."
msgstr "Disabilitare questa opzione potrebbe comportare un caricamento più veloce dei prodotti e un minor utilizzo della memoria a seconda della quantità di prodotti caricati."

#: admin/helpers/fooeventspos-phrases-helper.php:49
msgid "Only load POS orders"
msgstr "Carica solo gli ordini POS."

#: admin/helpers/fooeventspos-phrases-helper.php:50
msgid "Enable this option to only load orders that were placed in the POS."
msgstr "Abilita questa opzione per caricare solo gli ordini effettuati nel POS."

#: admin/helpers/fooeventspos-phrases-helper.php:51
msgid "Pin this product in the POS"
msgstr "Fissa questo prodotto nel POS."

#: admin/helpers/fooeventspos-phrases-helper.php:52
msgid "Pinning this product will make it always show at the top of listings in the POS."
msgstr "Pinnare questo prodotto lo farà sempre comparire in cima agli elenchi nel POS."

#: admin/helpers/fooeventspos-phrases-helper.php:53
msgid "Display attribute labels next to their values for product variations."
msgstr "Mostra le etichette degli attributi accanto ai loro valori per le varianti del prodotto."

#: admin/helpers/fooeventspos-phrases-helper.php:54
msgid "Show this product in the POS"
msgstr "Mostra questo prodotto nel POS."

#: admin/helpers/fooeventspos-phrases-helper.php:55
msgid "Choose whether this product should display in the POS. This setting allows you to have certain products hidden on your website, but visible in the POS, and vice versa."
msgstr "Scegli se questo prodotto deve essere visualizzato nel POS. Questa impostazione ti consente di nascondere determinati prodotti sul tuo sito web, ma visibili nel POS, e viceversa."

#: admin/helpers/fooeventspos-phrases-helper.php:56
msgid "The FooEvents POS app will only display products that have a status of 'In Stock'."
msgstr "L'app FooEvents POS mostrerà solo i prodotti che hanno uno stato di 'In Stock'."

#: admin/helpers/fooeventspos-phrases-helper.php:57
msgid "Show this variation in the POS"
msgstr "Mostra questa variazione nel POS."

#: admin/helpers/fooeventspos-phrases-helper.php:58
msgid "Choose whether this variation should display in the POS. This setting allows you to have certain product variations hidden on your website, but visible in the POS, and vice versa."
msgstr "Scegli se questa variazione deve essere visualizzata nel POS. Questa impostazione ti consente di nascondere alcune variazioni di prodotto sul tuo sito web, ma visibili nel POS, e viceversa."

#: admin/helpers/fooeventspos-phrases-helper.php:59
msgid "Display the FooEvents POS logo at the bottom of receipts and invoices."
msgstr "Mostra il logo di FooEvents POS in fondo ai ricevute e fatture."

#: admin/helpers/fooeventspos-phrases-helper.php:60
msgid "Enable the use of decimal values in the quantity field."
msgstr "Abilita l'uso dei valori decimali nel campo quantità."

#: admin/helpers/fooeventspos-phrases-helper.php:61
msgid "Use these settings for FooEvents POS"
msgstr "Utilizza queste impostazioni per il punto vendita di FooEvents."

#: admin/helpers/fooeventspos-phrases-helper.php:62
msgid "Use the same custom settings selected for the Check-ins app for the FooEvents POS interface."
msgstr "Utilizza le stesse impostazioni personalizzate selezionate per l'app Check-ins per l'interfaccia POS di FooEvents."

#: admin/helpers/fooeventspos-phrases-helper.php:63
msgid "All offline changes have been imported successfully."
msgstr "Tutte le modifiche offline sono state importate con successo."

#: admin/helpers/fooeventspos-phrases-helper.php:64
msgid "Select the user role(s) that should be loaded as customers in the FooEvents POS app."
msgstr "Seleziona il/i ruolo/i utente che dovrebbero essere caricati come clienti nell'app FooEvents POS."

#: admin/helpers/fooeventspos-phrases-helper.php:66
#, php-format
msgid "By default, access to FooEvents POS is restricted to users with the \"Administrator\" or \"Cashier\" user role. However, if you would like other users to have access to the FooEvents POS app but don't necessarily want to grant them Admin access to your site, you can manage permissions for other user roles by installing a free WordPress plugin called %1$sUser Role Editor%2$s."
msgstr "Di default, l'accesso a FooEvents POS è limitato agli utenti con il ruolo utente \"Amministratore\" o \"Cassiere\". Tuttavia, se desideri che altri utenti possano accedere all'app FooEvents POS ma non vuoi necessariamente concedere loro l'accesso Amministratore al tuo sito, puoi gestire le autorizzazioni per altri ruoli utente installando un plugin WordPress gratuito chiamato %1$sUser Role Editor%2$s."

#: admin/helpers/fooeventspos-phrases-helper.php:67
msgid "Changes made to customer settings might only reflect in the FooEvents POS app after resyncing your store data."
msgstr "Le modifiche apportate alle impostazioni dei clienti potrebbero riflettersi solo nell'app FooEvents POS dopo aver sincronizzato nuovamente i dati del tuo negozio."

#: admin/helpers/fooeventspos-phrases-helper.php:68
msgid "It appears that the \"Decimal Product Quantity for WooCommerce\" plugin is active. If you would like to use decimal quantities with FooEvents POS, you will need to deactivate this plugin and enable the FooEvents POS decimal quantity functionality in the Product settings tab."
msgstr "Sembra che il plugin \"Quantità del prodotto decimale per WooCommerce\" sia attivo. Se desideri utilizzare quantità decimali con FooEvents POS, dovrai disattivare questo plugin e abilitare la funzionalità di quantità decimale di FooEvents POS nella scheda Impostazioni prodotto."

#: admin/helpers/fooeventspos-phrases-helper.php:69
msgid "This setting will add decimal fields to all your products in FooEvents POS as well as your online store. We strongly recommend that you rigorously test this functionality on a staging site first before using it on a production site. Use of this functionality is at your own risk!"
msgstr "Questa impostazione aggiungerà campi decimali a tutti i tuoi prodotti in FooEvents POS e nel tuo negozio online. Ti consigliamo vivamente di testare rigorosamente questa funzionalità prima su un sito di staging prima di utilizzarla su un sito di produzione. L'uso di questa funzionalità è a tuo rischio!"

#: admin/helpers/fooeventspos-phrases-helper.php:71
#, php-format
msgid "You can set the default minimum cart quantity and step value on the %1$sWooCommerce Product Inventory settings page%2$s after first saving the settings on this page. If you would like to use different values instead of the defaults for a specific product or variation, you can manually set them on the product's edit screen by opening the inventory tab."
msgstr "Puoi impostare la quantità minima predefinita nel carrello e il valore dello step sulla pagina delle impostazioni dell'inventario del prodotto %1$sWooCommerce%2$s dopo aver salvato le impostazioni su questa pagina. Se desideri utilizzare valori diversi invece dei predefiniti per un prodotto o variazione specifici, puoi impostarli manualmente nella scheda inventario della modifica del prodotto."

#: admin/helpers/fooeventspos-phrases-helper.php:72
msgid "If you would like to use different values instead of the defaults for a specific product or variation, you can manually set them on the product's edit screen by opening the inventory tab."
msgstr "Se desideri utilizzare valori diversi anziché quelli predefiniti per un prodotto o una variazione specifica, puoi impostarli manualmente nella scheda di modifica del prodotto aprendo la scheda dell'inventario."

#: admin/helpers/fooeventspos-phrases-helper.php:73
msgid "e.g. kg, inches etc. (Products can have their own unique values for this setting)"
msgstr "ad es. kg, pollici ecc. (I prodotti possono avere valori unici per questa impostazione)"

#: admin/helpers/fooeventspos-phrases-helper.php:74
msgid "e.g. 1 or 0.01, 0.5 etc. (Products can have their own unique values for this setting)"
msgstr "ad esempio 1 o 0,01, 0,5 ecc. (I prodotti possono avere valori unici per questa impostazione)"

#: admin/helpers/fooeventspos-phrases-helper.php:75
msgid "Scan product barcodes with a Bluetooth scanner or search by product name, ID, SKU, or keyword in FooEvents POS."
msgstr "Scansiona i codici a barre dei prodotti con uno scanner Bluetooth o cerca per nome del prodotto, ID, SKU o parola chiave in FooEvents POS."

#: admin/helpers/fooeventspos-phrases-helper.php:76
msgid "Create dedicated cashiers with limited access, for example, only the FooEvents POS interface, no admin dashboard access."
msgstr "Crea cassieri dedicati con accesso limitato, ad esempio, solo all'interfaccia POS di FooEvents POS, senza accesso al cruscotto amministrativo."

#: admin/helpers/fooeventspos-phrases-helper.php:77
msgid "Scan or apply WooCommerce coupons during checkout to offer special deals and maintain continuity across sales channels."
msgstr "Scansiona o applica i coupon WooCommerce durante il checkout per offrire offerte speciali e mantenere la continuità attraverso i canali di vendita."

#: admin/helpers/fooeventspos-phrases-helper.php:78
msgid "Use your preferred custom order status plugin to seamlessly manage and track the order fulfillment process in-store and online."
msgstr "Utilizza il tuo plugin di stato dell'ordine personalizzato preferito per gestire e monitorare in modo fluido il processo di evasione degli ordini in negozio e online."

#: admin/helpers/fooeventspos-phrases-helper.php:79
msgid "Set product units such as kg, lb, mm, or inches for accurate quantity tracking and inventory management."
msgstr "Imposta le unità di prodotto come kg, lb, mm o pollici per un tracciamento accurato della quantità e la gestione dell'inventario."

#: admin/helpers/fooeventspos-phrases-helper.php:80
msgid "Search, view, and manage WooCommerce customer profiles including contact and billing details."
msgstr "Cerca, visualizza e gestisci i profili dei clienti di WooCommerce, inclusi i dettagli di contatto e di fatturazione."

#: admin/helpers/fooeventspos-phrases-helper.php:81
msgid "Switch to a dark interface to reduce eye strain, save battery life, and enjoy a more modern look in low-light environments."
msgstr "Passa a un'interfaccia scura per ridurre l'affaticamento degli occhi, risparmiare la batteria e godere di un aspetto più moderno in ambienti con poca luce."

#: admin/helpers/fooeventspos-phrases-helper.php:82
msgid "Enable decimal-based quantities for products—ideal for items sold by weight, length, or volume."
msgstr "Abilita le quantità basate su decimali per i prodotti, ideali per articoli venduti per peso, lunghezza o volume."

#: admin/helpers/fooeventspos-phrases-helper.php:83
msgid "Apply fixed or percentage discounts to individual products or the entire cart during checkout in the FooEvents POS apps."
msgstr "Applica sconti fissi o percentuali a singoli prodotti o all'intero carrello durante il checkout nelle app FooEvents POS."

#: admin/helpers/fooeventspos-phrases-helper.php:84
msgid "Sell event tickets, bookings, seats, and print tickets using the popular FooEvents plugin."
msgstr "Vendi biglietti per eventi, prenotazioni, posti a sedere e stampa biglietti utilizzando il popolare plugin FooEvents."

#: admin/helpers/fooeventspos-phrases-helper.php:85
msgid "Connect compatible printers, barcode scanners, and cash drawers to create a complete retail point of sale solution."
msgstr "Collega stampanti compatibili, lettori di codici a barre e casse per creare una soluzione completa per il punto vendita al dettaglio."

#: admin/helpers/fooeventspos-phrases-helper.php:86
msgid "Track and manage inventory in real time, including standard stock, decimal quantities, and custom units like kg or cm."
msgstr "Monitorare e gestire l'inventario in tempo reale, inclusi stock standard, quantità decimali e unità personalizzate come kg o cm."

#: admin/helpers/fooeventspos-phrases-helper.php:87
msgid "Print and email customer invoices or receipts directly from the FooEvents POS apps at checkout or at a later stage."
msgstr "Stampa e invia via email le fatture o ricevute ai clienti direttamente dalle app FooEvents POS al momento del pagamento o in un secondo momento."

#: admin/helpers/fooeventspos-phrases-helper.php:88
msgid "Use WooCommerce's built-in Local Pickup shipping method to manage and fulfill pickup orders through FooEvents POS."
msgstr "Utilizza il metodo di spedizione Local Pickup integrato in WooCommerce per gestire e soddisfare gli ordini di ritiro tramite FooEvents POS."

#: admin/helpers/fooeventspos-phrases-helper.php:89
msgid "Define minimum and maximum order quantities per product to control how much can be added to the cart."
msgstr "Definire le quantità minime e massime di ordine per prodotto per controllare quanto può essere aggiunto al carrello."

#: admin/helpers/fooeventspos-phrases-helper.php:90
msgid "Use FooEvents POS in your preferred language. Supports 9 major languages for global accessibility and ease of use."
msgstr "Usa FooEvents POS nella tua lingua preferita. Supporta 9 lingue principali per un'accessibilità globale e facilità d'uso."

#: admin/helpers/fooeventspos-phrases-helper.php:91
msgid "Use FooEvents POS without internet access. Sync or export orders once you’re back online using the import tool in your WordPress admin dashboard."
msgstr "Utilizza FooEvents POS senza accesso a internet. Sincronizza o esporta gli ordini una volta che sei di nuovo online utilizzando lo strumento di importazione nel pannello di amministrazione di WordPress."

#: admin/helpers/fooeventspos-phrases-helper.php:92
msgid "Get real-time alerts in the app when new orders are placed, so you never miss a sale whether you're in-store or on the go."
msgstr "Ricevi avvisi in tempo reale nell'app quando vengono effettuati nuovi ordini, così non perderai mai una vendita sia che tu sia in negozio o in movimento."

#: admin/helpers/fooeventspos-phrases-helper.php:93
msgid "View, create, update, and fulfill WooCommerce orders directly from the FooEvents POS apps in real time."
msgstr "Visualizza, crea, aggiorna e soddisfa gli ordini WooCommerce direttamente dalle app FooEvents POS in tempo reale."

#: admin/helpers/fooeventspos-phrases-helper.php:94
msgid "Accept in-person payments and record orders as cash, card, check, or any custom payment method you define."
msgstr "Accetta pagamenti di persona e registra ordini come contanti, carta, assegno o qualsiasi metodo di pagamento personalizzato che definisci."

#: admin/helpers/fooeventspos-phrases-helper.php:95
msgid "Support product customizations like toppings or engravings at checkout. All options sync with FooEvents POS for easy order fulfillment."
msgstr "Supporta personalizzazioni del prodotto come condimenti o incisioni al momento del pagamento. Tutte le opzioni si sincronizzano con FooEvents POS per una facile evasione degli ordini."

#: admin/helpers/fooeventspos-phrases-helper.php:96
msgid "Access and manage all your WooCommerce products in FooEvents POS, including variations, stock, and pricing."
msgstr "Accedi e gestisci tutti i tuoi prodotti WooCommerce in FooEvents POS, inclusi le varianti, lo stock e i prezzi."

#: admin/helpers/fooeventspos-phrases-helper.php:97
msgid "Issue full or partial refunds directly from the FooEvents POS apps for all supported payment methods."
msgstr "Emettere rimborsi completi o parziali direttamente dalle app FooEvents POS per tutti i metodi di pagamento supportati."

#: admin/helpers/fooeventspos-phrases-helper.php:98
msgid "Track store performance using WooCommerce Analytics reports directly in FooEvents POS. Monitor sales, orders, products, and key metrics."
msgstr "Monitorare le prestazioni del negozio utilizzando i report di analisi di WooCommerce direttamente in FooEvents POS. Monitorare le vendite, gli ordini, i prodotti e le metriche chiave."

#: admin/helpers/fooeventspos-phrases-helper.php:99
msgid "Allow customers to split payments using a combination of different payment methods such as cash, card, COD, Stripe, or Square."
msgstr "Consenti ai clienti di suddividere i pagamenti utilizzando una combinazione di diversi metodi di pagamento come contanti, carta, contrassegno, Stripe o Square."

#: admin/helpers/fooeventspos-phrases-helper.php:100
msgid "Accept in-person card payments using compatible Square devices, or manually enter card details for phone and remote orders."
msgstr "Accetta pagamenti con carta di credito di persona usando dispositivi Square compatibili, oppure inserisci manualmente i dettagli della carta per ordini telefonici e remoti."

#: admin/helpers/fooeventspos-phrases-helper.php:101
msgid "Process in-person payments using supported Stripe card readers or manually enter card details through the FooEvents POS apps."
msgstr "Elabora pagamenti di persona utilizzando i lettori di carte Stripe supportati o inserendo manualmente i dettagli della carta tramite le app FooEvents POS."

#: admin/helpers/fooeventspos-phrases-helper.php:102
msgid "Your WooCommerce tax settings are automatically applied at checkout for accurate tax calculations across all sales channels."
msgstr "Le impostazioni fiscali del tuo WooCommerce vengono applicate automaticamente al momento del pagamento per calcoli fiscali precisi su tutti i canali di vendita."

#: admin/helpers/fooeventspos-phrases-helper.php:103
msgid "Full support for WooCommerce product variations including size, color, and other custom attributes."
msgstr "Supporto completo per le variazioni di prodotto di WooCommerce, inclusi taglia, colore e altri attributi personalizzati."

#: admin/helpers/fooeventspos-phrases-helper.php:104
msgid "To sell and print tickets in FooEvents POS, the FooEvents for WooCommerce plugin must be installed and activated."
msgstr "Per vendere e stampare biglietti in FooEvents POS, il plugin FooEvents for WooCommerce deve essere installato e attivato."

#: admin/helpers/fooeventspos-phrases-helper.php:106
#, php-format
msgid "Please note that the app title should be unique so that the POS page does not conflict with any other pages on your site. If left empty, the POS page name will default to \"%1$s\" with a slug value of \"fooeventspos\"."
msgstr "Si prega di notare che il titolo dell'app dovrebbe essere unico in modo che la pagina POS non entri in conflitto con altre pagine sul tuo sito. Se lasciato vuoto, il nome della pagina POS verrà impostato di default su \"%1$s\" con un valore di slug \"FooEvents POS\"."

#: admin/helpers/fooeventspos-phrases-helper.php:108
#, php-format
msgid "If you have any questions regarding how to use or get the most out of FooEvents POS, we recommend that you visit our %1$sHelp Center%2$s where you will find many useful resources. If you can't find what you're looking for, feel free to %3$sget in touch%4$s."
msgstr "Se hai domande su come utilizzare al meglio FooEvents POS, ti consigliamo di visitare il nostro %1$sCentro assistenza%2$s dove troverai molte risorse utili. Se non trovi quello che cerchi, sentiti libero di %3$scontattarci%4$s."

#: admin/helpers/fooeventspos-phrases-helper.php:109
msgid "Import changes and new orders that were created while using FooEvents POS in offline mode directly into your WooCommerce database."
msgstr "Importa le modifiche e i nuovi ordini che sono stati creati mentre si utilizzava FooEvents POS in modalità offline direttamente nel database di WooCommerce."

#: admin/helpers/fooeventspos-phrases-helper.php:110
msgid "This functionality allows us to anonymously collect non-sensitive sales data for orders that are placed through the FooEvents POS app. We use this data to improve the product experience and publish insights which benefit the WordPress/WooCommerce community."
msgstr "Questa funzionalità ci consente di raccogliere in modo anonimo dati sulle vendite non sensibili per gli ordini effettuati tramite l'app FooEvents POS. Utilizziamo questi dati per migliorare l'esperienza del prodotto e pubblicare approfondimenti che beneficiano la comunità di WordPress/WooCommerce."

#: admin/helpers/fooeventspos-phrases-helper.php:111
msgid "POS payments made via the FooEvents POS."
msgstr "Pagamenti POS effettuati tramite il punto vendita FooEvents POS."

#: admin/helpers/fooeventspos-phrases-helper.php:112
msgid "FooEvents POS is a point of sale (POS) that turns any WooCommerce store into a secure omnichannel retail platform which allows you to sell online and in-person seamlessly."
msgstr "FooEvents POS per WooCommerce è un punto vendita (POS) che trasforma qualsiasi negozio WooCommerce in una piattaforma di vendita al dettaglio omnicanale sicura che ti consente di vendere online e di persona in modo fluido."

#: admin/helpers/fooeventspos-phrases-helper.php:113
msgid "Your store does not currently use HTTPS. Please ensure that you set up a valid SSL certificate."
msgstr "Il tuo negozio attualmente non utilizza HTTPS. Assicurati di configurare un certificato SSL valido."

#: admin/helpers/fooeventspos-phrases-helper.php:114
msgid "The FooEvents POS import tool allows you to import changes and new orders that were created while using FooEvents POS in offline mode directly into your WooCommerce database. This is useful if you placed a large volume of orders or made lots of changes while in offline mode and are having trouble syncing them through the app."
msgstr "Lo strumento di importazione di FooEvents POS ti consente di importare modifiche e nuovi ordini che sono stati creati mentre usavi FooEvents POS in modalità offline direttamente nel database di WooCommerce. Questo è utile se hai effettuato un grande volume di ordini o apportato molte modifiche mentre eri in modalità offline e stai avendo difficoltà a sincronizzarli tramite l'app."

#: admin/helpers/fooeventspos-phrases-helper.php:115
